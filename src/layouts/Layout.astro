---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  jsonLD?: object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  // TODO: ADD OG IMAGE — generate proper OG images per page
  ogImage,
  jsonLD = [],
  noindex = false,
} = Astro.props;

const siteName = 'aspectratio.dev';
const fullTitle = title.includes(siteName) ? title : `${title} — ${siteName}`;
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex,follow" />}

  <!-- OG / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- JSON-LD -->
  {jsonLD.map((ld) => (
    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  ))}

  <!-- Theme init (prevent flash) -->
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = stored || (prefersDark ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
      document.documentElement.classList.toggle('light', theme === 'light');
    })();
  </script>
</head>
<body class="min-h-screen flex flex-col">
  <slot name="header">
    <header class="border-b border-border-dark/50 backdrop-blur-md bg-bg/80 sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 group" id="logo-link">
          <div class="w-8 h-8 rounded-md bg-gradient-to-br from-teal-500 to-teal-600 flex items-center justify-center text-white font-bold text-sm transition-transform group-hover:scale-110">
            AR
          </div>
          <span class="font-semibold text-text-primary text-lg tracking-tight">
            aspect<span class="text-teal-500">ratio</span><span class="text-text-muted">.dev</span>
          </span>
        </a>
        <div class="hidden md:flex items-center gap-1">
          <a href="/calculator" class="px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all duration-150" id="nav-calculator">Calculator</a>
          <a href="/image" class="px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all duration-150" id="nav-image">Image Analyzer</a>
          <a href="/crop" class="px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all duration-150" id="nav-crop">Crop & Resize</a>
        </div>
        <div class="flex items-center gap-3">
          <button
            id="theme-toggle"
            class="w-9 h-9 rounded-md flex items-center justify-center text-text-muted hover:text-text-primary hover:bg-surface transition-all duration-150"
            aria-label="Toggle theme"
          >
            <svg class="w-5 h-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
            <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5" />
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
            </svg>
          </button>
          <!-- Mobile menu button -->
          <button
            id="mobile-menu-toggle"
            class="md:hidden w-9 h-9 rounded-md flex items-center justify-center text-text-muted hover:text-text-primary hover:bg-surface transition-all duration-150"
            aria-label="Toggle menu"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </nav>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-border-dark/50 bg-bg/95 backdrop-blur-md">
        <div class="px-4 py-3 space-y-1">
          <a href="/calculator" class="block px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all">Calculator</a>
          <a href="/image" class="block px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all">Image Analyzer</a>
          <a href="/crop" class="block px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all">Crop & Resize</a>
        </div>
      </div>
    </header>
  </slot>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="border-t border-border-dark/50 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-3">Tools</h3>
          <ul class="space-y-2">
            <li><a href="/calculator" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Calculator</a></li>
            <li><a href="/image" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Image Analyzer</a></li>
            <li><a href="/crop" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Crop & Resize</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-3">Common Ratios</h3>
          <ul class="space-y-2">
            <li><a href="/calculator?w=1920&h=1080" class="text-sm text-text-muted hover:text-teal-400 transition-colors">16:9</a></li>
            <li><a href="/calculator?w=1024&h=768" class="text-sm text-text-muted hover:text-teal-400 transition-colors">4:3</a></li>
            <li><a href="/calculator?w=1080&h=1080" class="text-sm text-text-muted hover:text-teal-400 transition-colors">1:1</a></li>
            <li><a href="/calculator?w=1080&h=1920" class="text-sm text-text-muted hover:text-teal-400 transition-colors">9:16</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-3">Developers</h3>
          <ul class="space-y-2">
            <li><a href="/css-aspect-ratio" class="text-sm text-text-muted hover:text-teal-400 transition-colors">CSS Generator</a></li>
            <li><a href="/tailwind-aspect-ratio" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Tailwind</a></li>
            <li><a href="/svg-viewbox" class="text-sm text-text-muted hover:text-teal-400 transition-colors">SVG viewBox</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-3">About</h3>
          <ul class="space-y-2">
            <li><span class="text-sm text-text-muted">100% client-side</span></li>
            <li><span class="text-sm text-text-muted">No uploads, no tracking</span></li>
            <li><span class="text-sm text-text-muted">Free & open</span></li>
          </ul>
        </div>
      </div>
      <div class="mt-10 pt-6 border-t border-border-dark/30 flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-sm text-text-muted">
          © {new Date().getFullYear()} aspectratio.dev — Built for developers & designers
        </p>
        <p class="text-xs text-text-muted/50">
          All calculations are performed locally in your browser. No data is sent to any server.
        </p>
      </div>
    </div>
  </footer>

  <script is:inline>
    // Theme toggle
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const html = document.documentElement;
      const isDark = html.classList.contains('dark');
      html.classList.toggle('dark', !isDark);
      html.classList.toggle('light', isDark);
      localStorage.setItem('theme', isDark ? 'light' : 'dark');
    });

    // Mobile menu toggle
    document.getElementById('mobile-menu-toggle')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
