---
import '../styles/global.css';
import type { IndexingTier } from '../lib/seo';
import { getRobotsMeta } from '../lib/seo';
import { site } from '../lib/site';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  keywords?: string;
  ogImage?: string;
  jsonLD?: object[];
  /** Indexing tier: 1 = hand-quality, 2 = substantive, 3 = programmatic (noindex) */
  tier?: IndexingTier;
  /** Override noindex directly (legacy support) */
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  keywords,
  // TODO: ADD OG IMAGE — generate proper OG images per page
  ogImage,
  jsonLD = [],
  tier = 1,
  noindex = false,
} = Astro.props;

const siteName = site.name;
const fullTitle = title.includes(siteName) ? title : `${title} — ${siteName}`;

// Determine robots meta from tier system (or explicit noindex override)
const robotsMeta = noindex ? 'noindex,follow' : getRobotsMeta(tier);
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <link rel="canonical" href={canonicalUrl} />
  {robotsMeta && <meta name="robots" content={robotsMeta} />}

  <!-- OG / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />

  <!-- Favicon -->
  <link rel="icon" href="/favicons/favicon.ico" sizes="48x48" />
  <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
  <link rel="icon" type="image/png" sizes="96x96" href="/favicons/favicon-96x96.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
  <link rel="manifest" href="/favicons/site.webmanifest" />

  <!-- Theme Color (mobile browser chrome) -->
  <meta name="theme-color" content="#0E1015" />

  <!-- JSON-LD -->
  {jsonLD.map((ld) => (
    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  ))}


</head>
<body class="min-h-screen flex flex-col">
  <slot name="header">
    <header class="border-b border-border-dark/50 backdrop-blur-md bg-bg/80 sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 group" id="logo-link">
          <img
            src="/favicons/favicon.svg"
            alt="Imagesize.org logo"
            class="w-8 h-8 rounded-md transition-transform group-hover:scale-110"
            width="32"
            height="32"
          />
          <span class="font-semibold text-text-primary text-lg tracking-tight">
            image<span class="text-teal-500">size</span><span class="text-text-muted">.org</span>
          </span>
        </a>
        <div class="hidden md:flex items-center gap-1">
          <a href="/crop-and-resize" class="px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all duration-150" id="nav-crop-resize">Crop & Resize</a>
          <a href="/reduce-image-size-in-kb" class="px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all duration-150" id="nav-compress">Compress</a>
          <a href="/image-size-for" class="px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all duration-150" id="nav-image-size-for">Sizes</a>
          <a href="/image" class="px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all duration-150" id="nav-image">Image Analyzer</a>
          <a href="/calculator" class="px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all duration-150" id="nav-calculator">Calculator</a>
          <a href="/embed" class="px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all duration-150" id="nav-embed">Embed</a>
        </div>
        <div class="flex items-center gap-3">
          <!-- Mobile menu button -->
          <button
            id="mobile-menu-toggle"
            class="md:hidden w-9 h-9 rounded-md flex items-center justify-center text-text-muted hover:text-text-primary hover:bg-surface transition-all duration-150"
            aria-label="Toggle menu"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </nav>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-border-dark/50 bg-bg/95 backdrop-blur-md">
        <div class="px-4 py-3 space-y-1">
          <a href="/crop-and-resize" class="block px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all">Crop & Resize</a>
          <a href="/reduce-image-size-in-kb" class="block px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all">Compress</a>
          <a href="/image-size-for" class="block px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all">Image Size For</a>
          <a href="/image" class="block px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all">Image Analyzer</a>
          <a href="/calculator" class="block px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all">Calculator</a>
          <a href="/embed" class="block px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-surface rounded-md transition-all">Embed Widget</a>
        </div>
      </div>
    </header>
  </slot>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="border-t border-border-dark/50 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-3">Tools</h3>
          <ul class="space-y-2">
            <li><a href="/crop-and-resize" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Crop & Resize</a></li>
            <li><a href="/reduce-image-size-in-kb" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Compress Image</a></li>
            <li><a href="/image-size-for" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Image Size For</a></li>
            <li><a href="/image" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Image Analyzer</a></li>
            <li><a href="/calculator" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Calculator</a></li>
            <li><a href="/embed" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Embed Widget</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-3">Popular Sizes</h3>
          <ul class="space-y-2">
            <li><a href="/linkedin-post-image-size" class="text-sm text-text-muted hover:text-teal-400 transition-colors">LinkedIn Post</a></li>
            <li><a href="/linkedin-cover-image-size" class="text-sm text-text-muted hover:text-teal-400 transition-colors">LinkedIn Cover</a></li>
            <li><a href="/google-forms-header-image-size" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Google Forms Header</a></li>
            <li><a href="/twitter-image-size" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Twitter/X Image</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-3">Reference</h3>
          <ul class="space-y-2">
            <li><a href="/linkedin-post-image-size" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Social Sizes</a></li>
            <li><a href="/css-aspect-ratio" class="text-sm text-text-muted hover:text-teal-400 transition-colors">CSS Generator</a></li>
            <li><a href="/embed" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Embed Widget</a></li>
            <li><a href="/calculator" class="text-sm text-text-muted hover:text-teal-400 transition-colors">Calculator</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-3">About</h3>
          <ul class="space-y-2">
            <li><span class="text-sm text-text-muted">100% client-side</span></li>
            <li><span class="text-sm text-text-muted">No uploads, no tracking</span></li>
            <li><span class="text-sm text-text-muted">Free & open</span></li>
          </ul>
        </div>
      </div>
      <div class="mt-10 pt-6 border-t border-border-dark/30 flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-sm text-text-muted">
          © {new Date().getFullYear()} {site.name} — Built for fast image sizing
        </p>
        <p class="text-xs text-text-muted/50">
          All calculations are performed locally in your browser. No data is sent to any server.
        </p>
      </div>
    </div>
  </footer>

  <script is:inline>
    // Mobile menu toggle
    document.getElementById('mobile-menu-toggle')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
