---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import FAQ from '../components/ui/FAQ.astro';
import RelatedTools from '../components/ui/RelatedTools.astro';
import ResizeIsland from '../components/islands/ResizeIsland';
import { buildWebApplicationLD, buildFAQLD, buildBreadcrumbLD, buildHowToLD } from '../lib/seo';
import { absoluteUrl, site } from '../lib/site';

const title = 'Crop and Resize Images Online';
const description = 'Crop, fit, stretch, or resize any image to exact pixels, aspect ratios, and platform presets. Live preview and full-resolution export in your browser.';
const pageUrl = absoluteUrl('/crop-and-resize');

const faqs = [
  {
    question: 'Is crop different from resize?',
    answer: '<strong>Resize</strong> changes the output pixel dimensions. <strong>Crop</strong> trims edges so the image fills a target shape without distortion. This page combines both, so you can set the size and choose Crop, Fit, or Stretch in one workflow.',
  },
  {
    question: 'What is the difference between Crop, Fit, and Stretch?',
    answer: '<strong>Crop</strong> removes pixels from the edges to fill the target. <strong>Fit</strong> keeps the whole image visible and adds padding or blur. <strong>Stretch</strong> forces the image into the exact size, which can distort proportions.',
  },
  {
    question: 'Can I use platform presets?',
    answer: 'Yes. Use Platform mode for presets like LinkedIn posts, LinkedIn covers, Google Forms headers, Twitter/X images, YouTube banners, Instagram posts, and more.',
  },
  {
    question: 'What resolution is the exported image?',
    answer: 'Exact and Platform modes export at the chosen pixel dimensions. Ratio mode keeps output based on your source image while matching the selected shape.',
  },
  {
    question: 'Is the image uploaded to a server?',
    answer: `No. Image processing runs locally in your browser using Canvas. Your file is not uploaded to ${site.name}.`,
  },
];

const jsonLD = [
  buildWebApplicationLD('Crop and Resize Tool', description, pageUrl),
  buildFAQLD(faqs),
  buildBreadcrumbLD([
    { name: 'Home', url: site.url },
    { name: 'Crop and Resize', url: pageUrl },
  ]),
  buildHowToLD(
    'How to crop and resize an image',
    'Crop, fit, stretch, or resize an image to exact pixels, aspect ratios, and platform presets.',
    [
      { name: 'Upload your image', text: 'Drag and drop an image onto the drop zone or click to browse. The tool reads the image locally.' },
      { name: 'Choose a target', text: 'Use Platform mode for common image sizes, Exact mode for specific pixels, or Ratio mode for proportions.' },
      { name: 'Choose crop, fit, or stretch', text: 'Crop fills the target, Fit keeps the whole image visible, and Stretch forces exact dimensions.' },
      { name: 'Export the result', text: 'Preview the result, choose PNG, JPG, or WebP, then download the final image.' },
    ],
    pageUrl
  ),
];

const relatedTools = [
  {
    title: 'Reduce Image Size in KB',
    description: 'Compress images to a target file size after dimensions are correct.',
    href: '/reduce-image-size-in-kb',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 14h16"/><path d="M8 10l4 4 4-4"/><path d="M12 4v10"/><rect x="4" y="18" width="16" height="2" rx="1"/></svg>',
  },
  {
    title: 'Image Analyzer',
    description: 'Check image dimensions, file size, ratio, and platform compatibility.',
    href: '/image',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>',
  },
  {
    title: 'Calculator',
    description: 'Compute aspect ratios from dimensions or find dimensions from a ratio.',
    href: '/calculator',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/></svg>',
  },
];
---

<Layout title={title} description={description} canonicalUrl={pageUrl} jsonLD={jsonLD}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Crop and Resize', url: '/crop-and-resize' },
    ]} />

    <div class="mb-8 max-w-3xl">
      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-3">
        Crop and resize images in one tool
      </h1>
      <p class="text-text-muted">
        Upload an image, choose a target size, then crop, fit, or stretch it for LinkedIn, Google Forms, Twitter/X, YouTube, Instagram, or any exact pixel requirement. <strong class="text-text-primary">Everything happens in your browser.</strong>
      </p>
    </div>

    <div class="mb-12">
      <ResizeIsland client:load />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-5xl mx-auto mb-12">
      <div class="p-4 bg-surface rounded-xl border border-border-dark/50">
        <h2 class="text-sm font-semibold text-text-primary mb-2">Resize</h2>
        <p class="text-sm text-text-muted leading-relaxed">Set exact output pixels, choose a platform preset, or keep a target ratio.</p>
      </div>
      <div class="p-4 bg-surface rounded-xl border border-border-dark/50">
        <h2 class="text-sm font-semibold text-text-primary mb-2">Crop or Fit</h2>
        <p class="text-sm text-text-muted leading-relaxed">Fill the frame by cropping, or keep the full image visible with padding or blur.</p>
      </div>
      <div class="p-4 bg-surface rounded-xl border border-border-dark/50">
        <h2 class="text-sm font-semibold text-text-primary mb-2">Export</h2>
        <p class="text-sm text-text-muted leading-relaxed">Download PNG, JPG, or WebP at full resolution without uploading the image.</p>
      </div>
    </div>

    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">How to Use the Tool</h2>
      <div class="text-sm text-text-muted space-y-4 leading-relaxed">
        <p>
          <strong class="text-text-primary">Target mode</strong> controls the final size. <em>Platform</em> gives one-click presets for common upload requirements, <em>Exact</em> lets you set precise pixels, and <em>Ratio</em> targets proportions like 16:9 or 1:1.
        </p>
        <p>
          <strong class="text-text-primary">Fit mode</strong> controls how your image fills that target. <em>Crop</em> trims edges, <em>Fit</em> adds padding or blur while keeping the whole image visible, and <em>Stretch</em> scales the image into the exact frame.
        </p>
        <p>
          Preview the result in real time, choose PNG, JPG, or WebP, then export the final image.
        </p>
      </div>
    </div>

    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Frequently Asked Questions</h2>
      <FAQ items={faqs} />
    </div>

    <div class="max-w-3xl mx-auto mb-8">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Related Tools</h2>
      <RelatedTools tools={relatedTools} />
    </div>

    <div class="max-w-3xl mx-auto">
      <p class="text-xs text-text-muted/40">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    </div>
  </div>
</Layout>
