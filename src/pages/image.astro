---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import FAQ from '../components/ui/FAQ.astro';
import RelatedTools from '../components/ui/RelatedTools.astro';
import ImageAnalyzerIsland from '../components/islands/ImageAnalyzerIsland';
import { buildWebApplicationLD, buildFAQLD, buildBreadcrumbLD } from '../lib/seo';

const title = 'Image Size Analyzer — Check Dimensions, Ratio & File Size';
const description = 'Upload any image to instantly detect its dimensions, file size, aspect ratio, and compatibility with LinkedIn, Twitter/X, Google Forms, YouTube, Instagram, and more. 100% client-side.';

const faqs = [
  {
    question: 'Is my image uploaded to a server?',
    answer: 'No. All analysis happens entirely in your browser using the Canvas API. Your image never leaves your device — no uploads, no server processing, complete privacy.',
  },
  {
    question: 'What image formats are supported?',
    answer: 'Any format your browser supports: PNG, JPEG, WebP, GIF, BMP, AVIF, and more. There\'s no file size limit beyond your browser\'s memory.',
  },
  {
    question: 'What does the compatibility grid show?',
    answer: 'For each major social platform and format (YouTube thumbnail, Instagram Story, TikTok video, etc.), it shows whether your image\'s aspect ratio matches (✅), is close enough to crop (🟡), or is the wrong shape entirely (❌). Click "Fix" to open the crop tool with the right target dimensions.',
  },
  {
    question: 'Can I export the image at a different size?',
    answer: 'For individual images, use the "Fix" link next to any platform to open the Crop & Resize tool, where you can crop or pad to the exact dimensions and export. Batch export is available in the Pro tier.',
  },
];

const jsonLD = [
  buildWebApplicationLD('Image Size Analyzer', description, 'https://imagesize.org/image'),
  buildFAQLD(faqs),
  buildBreadcrumbLD([
    { name: 'Home', url: 'https://imagesize.org' },
    { name: 'Image Analyzer', url: 'https://imagesize.org/image' },
  ]),
];

const relatedTools = [
  {
    title: 'Calculator',
    description: 'Compute aspect ratios from dimensions or find dimensions from a ratio.',
    href: '/calculator',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/></svg>',
  },
  {
    title: 'Crop & Resize',
    description: 'Crop, fit, stretch, or resize images to any target size with live preview.',
    href: '/crop-and-resize',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6.13 1L6 16a2 2 0 002 2h15"/><path d="M1 6.13L16 6a2 2 0 012 2v15"/></svg>',
  },
];
---

<Layout title={title} description={description} jsonLD={jsonLD}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Image Analyzer', url: '/image' },
    ]} />

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-3">
        Image Size Analyzer
      </h1>
      <p class="text-text-muted max-w-2xl">
        Drop any image to instantly see its dimensions, file size, aspect ratio, and how it fits across major social media and upload targets. <strong class="text-text-primary">100% client-side</strong> — nothing is uploaded.
      </p>
    </div>

    <!-- Analyzer Island -->
    <div class="mb-12">
      <ImageAnalyzerIsland client:load />
    </div>

    <!-- On-page explainer -->
    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">How It Works</h2>
      <div class="text-sm text-text-muted space-y-4 leading-relaxed">
        <p>
          When you upload an image, the analyzer uses the browser's <strong class="text-text-primary">Canvas API</strong> to read its native dimensions (width × height in pixels). From there, it computes the simplified ratio, decimal ratio, and orientation.
        </p>
        <p>
          The <strong class="text-text-primary">platform compatibility grid</strong> compares your image's ratio against recommended dimensions for YouTube, Instagram, Facebook, X/Twitter, LinkedIn, TikTok, Pinterest, and Twitch. Each platform has specific size requirements — this tool tells you instantly whether your image fits, needs a crop, or is the wrong shape entirely.
        </p>
        <p>
          If an image needs adjustment, click the <strong class="text-text-primary">"Fix"</strong> link to open the Crop & Resize tool with the correct target dimensions pre-filled, making it a one-click workflow from analysis to export.
        </p>
      </div>
    </div>

    <!-- FAQ -->
    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Frequently Asked Questions</h2>
      <FAQ items={faqs} />
    </div>

    <!-- Related Tools -->
    <div class="max-w-3xl mx-auto mb-8">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Related Tools</h2>
      <RelatedTools tools={relatedTools} />
    </div>

    <div class="max-w-3xl mx-auto">
      <p class="text-xs text-text-muted/40">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    </div>
  </div>
</Layout>
