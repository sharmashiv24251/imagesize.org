---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import FAQ from '../components/ui/FAQ.astro';
import RelatedTools from '../components/ui/RelatedTools.astro';
import ResizeIsland from '../components/islands/ResizeIsland';
import { buildWebApplicationLD, buildFAQLD, buildBreadcrumbLD, buildHowToLD } from '../lib/seo';

const title = 'Crop & Resize Images — Free Online Tool';
const description = 'Crop, fit, or stretch any image to a target ratio, exact dimensions, or platform preset. Live preview with full-resolution export — 100% in your browser.';

const faqs = [
  {
    question: 'What\'s the difference between crop, fit, and stretch?',
    answer: '<strong>Crop</strong> removes pixels from the edges to fill the target ratio — your image stays sharp but edges are trimmed. <strong>Fit</strong> (letterbox/padding) keeps the whole image visible and fills the remaining space with a blurred background or solid color. <strong>Stretch</strong> scales the image to fit exactly, which may distort proportions.',
  },
  {
    question: 'What\'s the difference between Ratio, Exact, and Platform modes?',
    answer: '<strong>Ratio</strong> mode targets an aspect ratio (e.g. 16:9) — output size is based on your source image. <strong>Exact</strong> mode outputs at specific pixel dimensions (e.g. 1920×1080). <strong>Platform</strong> mode uses recommended dimensions for social media platforms like YouTube, Instagram, or TikTok.',
  },
  {
    question: 'What resolution is the exported image?',
    answer: 'In Ratio mode, output preserves your source resolution — only pixels are trimmed or added. In Exact and Platform modes, the output matches your chosen pixel dimensions exactly.',
  },
  {
    question: 'Can I change the fill color in Fit mode?',
    answer: 'Yes — in Fit mode, switch between Blur (a blurred version of your image as background) or Color (pick any solid color).',
  },
  {
    question: 'Is this tool free?',
    answer: 'Yes, unlimited single-image processing is free. All processing happens locally in your browser — nothing is uploaded.',
  },
];

const jsonLD = [
  buildWebApplicationLD('Crop & Resize Tool', description, 'https://aspectratio.dev/resize'),
  buildFAQLD(faqs),
  buildBreadcrumbLD([
    { name: 'Home', url: 'https://aspectratio.dev' },
    { name: 'Crop & Resize', url: 'https://aspectratio.dev/resize' },
  ]),
  buildHowToLD(
    'How to Crop or Resize an Image to Any Aspect Ratio',
    'Crop, fit, or stretch any image to a target ratio or exact dimensions with live preview and full-resolution export.',
    [
      { name: 'Upload your image', text: 'Drag and drop an image onto the drop zone or click to browse. The tool reads the image locally — no upload to any server.' },
      { name: 'Choose your target', text: 'Use Ratio mode for aspect ratio presets (16:9, 4:3, etc.), Exact mode for specific pixel dimensions, or Platform mode for social media presets.' },
      { name: 'Select fit mode', text: 'Choose Crop to trim edges, Fit to add fill around the image, or Stretch to scale to fit exactly.' },
      { name: 'Export the result', text: 'Preview the result in real time, then click Export PNG to download at full resolution.' },
    ],
    'https://aspectratio.dev/resize'
  ),
];

const relatedTools = [
  {
    title: 'Image Analyzer',
    description: 'Upload an image for instant ratio detection and platform compatibility check.',
    href: '/image',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>',
  },
  {
    title: 'Calculator',
    description: 'Compute aspect ratios from dimensions or find dimensions from a ratio.',
    href: '/calculator',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/></svg>',
  },
];
---

<Layout title={title} description={description} jsonLD={jsonLD}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Crop & Resize', url: '/resize' },
    ]} />

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-3">
        Crop & Resize to Any Aspect Ratio
      </h1>
      <p class="text-text-muted max-w-2xl">
        Upload an image, choose a target ratio, exact size, or platform preset — then crop, fit, or stretch to match. Live preview, full-resolution export. <strong class="text-text-primary">Everything happens in your browser.</strong>
      </p>
    </div>

    <div class="mb-12">
      <ResizeIsland client:load />
    </div>

    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">How to Use the Tool</h2>
      <div class="text-sm text-text-muted space-y-4 leading-relaxed">
        <p>
          <strong class="text-text-primary">Target mode</strong> controls what you're aiming for. <em>Ratio</em> lets you pick an aspect ratio (16:9, 4:3, 1:1, etc.) and the output size scales from your source image. <em>Exact</em> lets you set precise pixel dimensions like 1920×1080. <em>Platform</em> gives you one-click presets for YouTube, Instagram, TikTok, and more.
        </p>
        <p>
          <strong class="text-text-primary">Fit mode</strong> controls how the image fills the target. <em>Crop</em> trims pixels from the center-out to fit the ratio — nothing is added, but edges are removed. <em>Fit</em> keeps your full image visible and fills any remaining space with a blurred background or solid color. <em>Stretch</em> scales the image to exactly fill the target, which can distort proportions.
        </p>
        <p>
          <strong class="text-text-primary">Step 4:</strong> Preview the result in real time, then click <em>Export PNG</em> to download at full resolution.
        </p>
      </div>
    </div>

    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Frequently Asked Questions</h2>
      <FAQ items={faqs} />
    </div>

    <div class="max-w-3xl mx-auto mb-8">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Related Tools</h2>
      <RelatedTools tools={relatedTools} />
    </div>

    <div class="max-w-3xl mx-auto">
      <p class="text-xs text-text-muted/40">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    </div>
  </div>
</Layout>
