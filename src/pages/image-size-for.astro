---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import FAQ from '../components/ui/FAQ.astro';
import RelatedTools from '../components/ui/RelatedTools.astro';
import ImageSizeForIsland from '../components/islands/ImageSizeForIsland';
import { buildBreadcrumbLD, buildFAQLD, buildWebApplicationLD } from '../lib/seo';
import { absoluteUrl, site } from '../lib/site';
import { getImageSizeForOptions } from '../lib/imageSizeFor';

const title = 'Image Size For or Of Every Platform, Document, Print, and Social Upload';
const description = 'Search image size for or image size of LinkedIn posts, WhatsApp DP, YouTube Shorts, PAN card, Facebook covers, A4 paper, wallpapers, banners, printing, and every platform preset on imagesize.org.';
const canonicalUrl = absoluteUrl('/image-size-for');
const options = getImageSizeForOptions();
const featuredOptions = options.filter((item) => item.featured).slice(0, 12);

const faqs = [
  {
    question: 'What is this image size for page?',
    answer: 'It is a searchable index of image-size intents, including both “image size for” and “image size of” phrasing: social posts, profile photos, cover images, document photos, print sizes, ads, screens, and platform presets. Pick an option to open the matching guide or crop and resize workspace.',
  },
  {
    question: 'Does it include all platform presets?',
    answer: 'Yes. The list includes every current option from the shared platform preset database, plus the uploaded A-Z product list and common search terms like WhatsApp DP, PAN card, wallpaper, website, Amazon listing, visa photos, exam forms, email headers, and shirt artwork.',
  },
  {
    question: 'Can I use it without uploading an image?',
    answer: 'Yes. You can browse dimensions first, then upload only when you open the crop and resize tool. Image processing stays in your browser.',
  },
  {
    question: 'Are document and marketplace sizes official?',
    answer: 'Some document, marketplace, and apparel rows are practical workspaces rather than official rules. Always check the destination form, marketplace, or printer before final upload.',
  },
];

const jsonLD = [
  buildWebApplicationLD('Image Size For Search', description, canonicalUrl),
  buildFAQLD(faqs),
  buildBreadcrumbLD([
    { name: 'Home', url: site.url },
    { name: 'Image Size For', url: canonicalUrl },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Image size for presets',
    itemListElement: featuredOptions.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: `Image size for ${item.term}`,
      url: absoluteUrl(item.href),
    })),
  },
];

const relatedTools = [
  {
    title: 'Crop & Resize',
    description: 'Upload an image and export it to any selected image size.',
    href: '/crop-and-resize',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>',
  },
  {
    title: 'Reduce Image Size in KB',
    description: 'Compress images after dimensions are right.',
    href: '/reduce-image-size-in-kb',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 14h16"/><path d="M8 10l4 4 4-4"/><path d="M12 4v10"/><rect x="4" y="18" width="16" height="2" rx="1"/></svg>',
  },
  {
    title: 'Image Analyzer',
    description: 'Check an uploaded image against platform sizes.',
    href: '/image',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>',
  },
];
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} jsonLD={jsonLD}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Image Size For', url: '/image-size-for' },
    ]} />

    <div class="mb-8 max-w-3xl">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-teal-500/10 border border-teal-500/20 text-teal-400 text-xs font-medium mb-5">
        {options.length} searchable image-size options
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary tracking-tight mb-3">
        Image size for or of any upload
      </h1>
      <p class="text-text-muted text-lg leading-relaxed">
        Search the phrases people actually type: image size for LinkedIn post, image size of WhatsApp DP, YouTube Shorts, PAN card, A4 paper, Facebook cover, wallpaper, website banner, printing, and every preset from the platform database.
      </p>
    </div>

    <section class="mb-12">
      <ImageSizeForIsland client:load options={options} />
    </section>

    <section class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Popular “image size for” searches</h2>
      <div class="flex flex-wrap gap-2">
        {featuredOptions.map((item) => (
          <a href={item.href} class="px-3 py-2 rounded-lg bg-surface border border-border-dark/50 text-sm text-text-muted hover:text-text-primary hover:border-teal-500/30 transition-colors">
            image size for <strong class="text-text-primary">{item.term}</strong>
          </a>
        ))}
      </div>
    </section>

    <section class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">How to use the list</h2>
      <div class="text-sm text-text-muted space-y-4 leading-relaxed">
        <p>
          Start typing after <strong class="text-text-primary">image size for</strong>, or paste the full phrase with <strong class="text-text-primary">image size of</strong>. The list searches platform names, format names, aliases, ratios, and pixel dimensions. Click a row to open the matching guide or a pre-filled crop and resize workspace.
        </p>
        <p>
          Platform rows come from the same shared preset database used by the analyzer and resize tool, so new platform sizes appear here automatically. Practical rows for documents, marketplaces, websites, and apparel are included as fast starting points.
        </p>
      </div>
    </section>

    <section class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Frequently Asked Questions</h2>
      <FAQ items={faqs} />
    </section>

    <section class="max-w-3xl mx-auto mb-8">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Related Tools</h2>
      <RelatedTools tools={relatedTools} />
    </section>

    <div class="max-w-3xl mx-auto">
      <p class="text-xs text-text-muted/40">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    </div>
  </div>
</Layout>
