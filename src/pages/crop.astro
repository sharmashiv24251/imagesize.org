---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import FAQ from '../components/ui/FAQ.astro';
import RelatedTools from '../components/ui/RelatedTools.astro';
import CropVisualizerIsland from '../components/islands/CropVisualizerIsland';
import { buildWebApplicationLD, buildFAQLD, buildBreadcrumbLD } from '../lib/seo';

const title = 'Crop & Resize Images to Any Aspect Ratio — Free Online Tool';
const description = 'Crop, pad, or letterbox any image to a target aspect ratio. Live canvas preview, preset ratios, color picker for padding. Export full-resolution PNG — 100% in your browser.';

const faqs = [
  {
    question: 'What\'s the difference between crop, padding, and letterbox?',
    answer: '<strong>Crop</strong> removes pixels from the edges to fit the target ratio — your image gets smaller but stays sharp. <strong>Padding</strong> adds colored bars around the image to fill the target ratio — nothing is removed. <strong>Letterbox</strong> is similar to padding but uses black bars, like cinema films shown on a wider screen.',
  },
  {
    question: 'What resolution is the exported image?',
    answer: 'Full resolution. The export uses the original pixel dimensions of your image, not the scaled preview shown on screen. If you crop a 4000×3000 image to 16:9, you get a 4000×2250 output.',
  },
  {
    question: 'Can I change the padding color?',
    answer: 'Yes — in Padding mode, use the color picker to choose any background color. Letterbox mode always uses black, matching the cinema convention.',
  },
  {
    question: 'Is this tool free?',
    answer: 'Yes, unlimited single-image crops are free. Batch processing (multiple images at once) is available in the Pro tier.',
  },
];

const jsonLD = [
  buildWebApplicationLD('Crop & Resize Tool', description, 'https://aspectratio.dev/crop'),
  buildFAQLD(faqs),
  buildBreadcrumbLD([
    { name: 'Home', url: 'https://aspectratio.dev' },
    { name: 'Crop & Resize', url: 'https://aspectratio.dev/crop' },
  ]),
];

const relatedTools = [
  {
    title: 'Calculator',
    description: 'Compute aspect ratios from dimensions or find dimensions from a ratio.',
    href: '/calculator',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/></svg>',
  },
  {
    title: 'Image Analyzer',
    description: 'Upload an image for instant ratio detection and platform compatibility.',
    href: '/image',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>',
  },
];
---

<Layout title={title} description={description} jsonLD={jsonLD}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Crop & Resize', url: '/crop' },
    ]} />

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-3">
        Crop & Resize to Any Aspect Ratio
      </h1>
      <p class="text-text-muted max-w-2xl">
        Upload an image and choose crop, padding, or letterbox mode to match any target ratio. Live preview, preset ratios, full-resolution export. <strong class="text-text-primary">Everything happens in your browser.</strong>
      </p>
    </div>

    <!-- Crop Visualizer Island -->
    <div class="mb-12">
      <CropVisualizerIsland client:load />
    </div>

    <!-- On-page explainer -->
    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">How to Use the Crop Tool</h2>
      <div class="text-sm text-text-muted space-y-4 leading-relaxed">
        <p>
          <strong class="text-text-primary">Step 1:</strong> Upload your image by dragging it onto the drop zone or clicking to browse. The tool reads the image locally — no upload to any server.
        </p>
        <p>
          <strong class="text-text-primary">Step 2:</strong> Choose your target aspect ratio. Click a preset (16:9, 4:3, 1:1, etc.) or enter custom values. Coming from the Image Analyzer? The target is pre-filled automatically.
        </p>
        <p>
          <strong class="text-text-primary">Step 3:</strong> Select your mode. <em>Crop</em> trims pixels from the edges. <em>Padding</em> adds bars in your chosen color. <em>Letterbox</em> adds black bars (the cinema look).
        </p>
        <p>
          <strong class="text-text-primary">Step 4:</strong> Preview the result in real time, then click <em>Export PNG</em> to download at full resolution.
        </p>
      </div>
    </div>

    <!-- FAQ -->
    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Frequently Asked Questions</h2>
      <FAQ items={faqs} />
    </div>

    <!-- Related Tools -->
    <div class="max-w-3xl mx-auto mb-8">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Related Tools</h2>
      <RelatedTools tools={relatedTools} />
    </div>

    <div class="max-w-3xl mx-auto">
      <p class="text-xs text-text-muted/40">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    </div>
  </div>
</Layout>
