---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import FAQ from '../components/ui/FAQ.astro';
import RelatedTools from '../components/ui/RelatedTools.astro';
import ImageCompressorIsland from '../components/islands/ImageCompressorIsland';
import { buildBreadcrumbLD, buildFAQLD, buildHowToLD, buildWebApplicationLD } from '../lib/seo';
import { absoluteUrl, site } from '../lib/site';

const title = 'Reduce Image Size in KB: Free Online Image Compressor';
const description = 'Reduce image size to a target KB in your browser. Compress JPG, PNG, and WebP files with optional max width and height. No uploads.';
const canonicalUrl = absoluteUrl('/reduce-image-size-in-kb');

const faqs = [
  {
    question: 'How do I reduce image size in KB?',
    answer: 'Upload an image, choose a target KB size, select JPG or WebP, and click Reduce Image Size. The tool adjusts export quality and optional dimensions in your browser.',
  },
  {
    question: 'Are my images uploaded?',
    answer: `No. ${site.name} compresses images locally with browser Canvas. Your image does not leave your device.`,
  },
  {
    question: 'Why is PNG harder to compress?',
    answer: 'Browser PNG export is mostly lossless, so quality settings do not shrink PNGs the way JPG or WebP quality settings do. Use WebP or JPG when you need a smaller KB file.',
  },
  {
    question: 'What if the target KB cannot be reached?',
    answer: 'The tool shows the closest result it can make. To go smaller, choose WebP, reduce max width or height, or use a simpler image.',
  },
];

const jsonLD = [
  buildWebApplicationLD('Reduce Image Size in KB', description, canonicalUrl),
  buildFAQLD(faqs),
  buildBreadcrumbLD([
    { name: 'Home', url: site.url },
    { name: 'Reduce Image Size in KB', url: canonicalUrl },
  ]),
  buildHowToLD(
    'How to reduce image size in KB',
    'Compress an image to a target KB size in your browser.',
    [
      { name: 'Upload your image', text: 'Drop an image into the compressor or click to browse.' },
      { name: 'Set target KB', text: 'Enter the maximum file size you want, such as 100 KB or 250 KB.' },
      { name: 'Choose format and dimensions', text: 'Use WebP or JPG for the smallest files, and optionally cap width or height.' },
      { name: 'Download', text: 'Download the compressed result after processing finishes.' },
    ],
    canonicalUrl
  ),
];

const relatedTools = [
  {
    title: 'Crop & Resize',
    description: 'Resize and crop images to exact pixels or social platform presets.',
    href: '/crop-and-resize',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>',
  },
  {
    title: 'Image Analyzer',
    description: 'Check dimensions, ratio, file type, and platform compatibility.',
    href: '/image',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>',
  },
];
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} jsonLD={jsonLD}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Reduce Image Size in KB', url: '/reduce-image-size-in-kb' },
    ]} />

    <div class="mb-8 max-w-3xl">
      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-3">
        Reduce Image Size in KB
      </h1>
      <p class="text-text-muted">
        Compress an image to a target file size for forms, uploads, job portals, social platforms, and email. Everything runs locally in your browser.
      </p>
    </div>

    <section class="mb-12">
      <ImageCompressorIsland client:load />
    </section>

    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">How image size reduction works</h2>
      <div class="text-sm text-text-muted space-y-4 leading-relaxed">
        <p>
          File size depends on pixel dimensions, image complexity, format, and export quality. Reducing dimensions usually saves the most space; switching from PNG to WebP or JPG can reduce even more.
        </p>
        <p>
          This compressor tries multiple quality levels to get under your target KB. If the image cannot reach the target cleanly, it keeps the closest result and tells you what to adjust.
        </p>
      </div>
    </div>

    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Frequently Asked Questions</h2>
      <FAQ items={faqs} />
    </div>

    <div class="max-w-3xl mx-auto mb-8">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Related Tools</h2>
      <RelatedTools tools={relatedTools} />
    </div>
  </div>
</Layout>
