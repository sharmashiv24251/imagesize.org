---
import Layout from '../layouts/Layout.astro';
import ResizeIsland from '../components/islands/ResizeIsland';
import CalculatorIsland from '../components/islands/CalculatorIsland';
import { buildBreadcrumbLD, buildWebApplicationLD, buildWebSiteLD } from '../lib/seo';
import { absoluteUrl, site } from '../lib/site';

const title = 'Image Size Tool: Resize, Crop, Compress & Check Dimensions';
const description = 'Find and fix the right image size for LinkedIn posts, LinkedIn covers, Google Forms headers, Twitter/X images, and KB-limited uploads. Private browser tools, no uploads.';

const jsonLD = [
  buildWebSiteLD(),
  buildWebApplicationLD('Image Size Tool', description, site.url),
  buildBreadcrumbLD([
    { name: 'Home', url: site.url },
  ]),
];

const popularSizes = [
  {
    title: 'LinkedIn Post Image Size',
    size: '1200x628',
    description: 'Landscape post and ad image, with square and vertical options.',
    href: '/linkedin-post-image-size',
  },
  {
    title: 'LinkedIn Cover Image Size',
    size: '1584x396',
    description: 'Profile background first, plus LinkedIn Page cover guidance.',
    href: '/linkedin-cover-image-size',
  },
  {
    title: 'Google Forms Header',
    size: '1600x400',
    description: 'Practical 4:1 template for form headers and theme images.',
    href: '/google-forms-header-image-size',
  },
  {
    title: 'Twitter/X Image Size',
    size: '1200x675',
    description: 'Post image preset with header and profile photo sizes nearby.',
    href: '/twitter-image-size',
  },
  {
    title: 'Image Size For...',
    size: 'Search',
    description: 'Find sizes for WhatsApp DP, PAN card, wallpaper, printing, and every preset.',
    href: '/image-size-for',
  },
  {
    title: 'Reduce Image Size in KB',
    size: 'Target KB',
    description: 'Compress JPG, PNG, and WebP files for upload limits.',
    href: '/reduce-image-size-in-kb',
  },
];

const tools = [
  {
    title: 'Resize & Crop',
    description: 'Upload an image, choose exact pixels or platform presets, then export.',
    href: '/crop-and-resize',
  },
  {
    title: 'Compress Image',
    description: 'Reduce image size to a target KB with local browser compression.',
    href: '/reduce-image-size-in-kb',
  },
  {
    title: 'Image Analyzer',
    description: 'Check dimensions, file size, ratio, and platform compatibility.',
    href: '/image',
  },
  {
    title: 'Image Size For',
    description: 'Search every “image size for” option from social, print, document, and platform presets.',
    href: '/image-size-for',
  },
  {
    title: 'Aspect Ratio Calculator',
    description: 'Compute ratios and dimensions when you need the math behind the size.',
    href: '/calculator',
  },
];
---

<Layout title={title} description={description} canonicalUrl={absoluteUrl('/')} jsonLD={jsonLD}>
  <section class="relative overflow-hidden border-b border-border-dark/30">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(15,181,161,0.10),transparent_42%)] pointer-events-none" />

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-14 pb-10 sm:pt-20 sm:pb-14">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-teal-500/10 border border-teal-500/20 text-teal-400 text-xs font-medium mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse-soft" />
          Resize, crop, compress, check dimensions
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-text-primary tracking-tight leading-[1.08] mb-5">
          Find and fix the right image size
        </h1>

        <p class="text-lg sm:text-xl text-text-muted max-w-2xl mb-8 leading-relaxed">
          Prepare images for LinkedIn posts, LinkedIn covers, Google Forms headers, Twitter/X, and strict KB upload limits. Your files stay on your device.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="#resize-tool"
            class="px-6 py-3 bg-teal-500 hover:bg-teal-600 text-white font-medium rounded-lg transition-all duration-150 hover:shadow-lg hover:shadow-teal-500/25 inline-flex items-center justify-center"
          >
            Resize an Image
          </a>
          <a
            href="/reduce-image-size-in-kb"
            class="px-6 py-3 bg-surface hover:bg-surface-2 text-text-primary font-medium rounded-lg border border-border-dark/50 hover:border-teal-500/30 transition-all duration-150 inline-flex items-center justify-center"
          >
            Reduce Image Size in KB
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="resize-tool" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-5 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
      <div>
        <h2 class="text-2xl font-semibold text-text-primary">Resize and crop to the exact size</h2>
        <p class="text-sm text-text-muted mt-1">Starts on the LinkedIn post preset. Switch platform, exact size, crop, fit, or stretch anytime.</p>
      </div>
      <a href="/crop-and-resize" class="text-sm text-teal-400 hover:text-teal-300">Open full crop and resize tool</a>
    </div>

    <div class="bg-surface rounded-xl border border-border-dark/50 p-4 sm:p-5">
      <ResizeIsland
        client:load
        initialPlatform="LinkedIn"
        initialFormat="Post Image"
        initialWidth={1200}
        initialHeight={628}
      />
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <div class="mb-5">
      <h2 class="text-2xl font-semibold text-text-primary">Popular image sizes</h2>
      <p class="text-sm text-text-muted mt-1">Fast paths for the searches people usually need before an upload.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-3">
      {popularSizes.map((item) => (
        <a
          href={item.href}
          class="group p-4 bg-surface rounded-xl border border-border-dark/50 hover:border-teal-500/30 hover:bg-surface-2/30 transition-all duration-200"
        >
          <div class="font-mono text-lg font-semibold text-teal-400 tabular-nums mb-2">{item.size}</div>
          <h3 class="font-medium text-text-primary group-hover:text-teal-400 transition-colors mb-1">{item.title}</h3>
          <p class="text-xs text-text-muted leading-relaxed">{item.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <h2 class="text-2xl font-semibold text-text-primary mb-5">Tools</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
      {tools.map((tool) => (
        <a
          href={tool.href}
          class="group p-5 bg-surface rounded-xl border border-border-dark/50 hover:border-teal-500/30 hover:bg-surface-2/20 transition-all duration-200"
        >
          <h3 class="font-medium text-text-primary group-hover:text-teal-400 transition-colors mb-2">{tool.title}</h3>
          <p class="text-sm text-text-muted leading-relaxed">{tool.description}</p>
          <div class="mt-4 text-xs text-teal-400 opacity-0 group-hover:opacity-100 transition-opacity">Open tool</div>
        </a>
      ))}
    </div>
  </section>

  <section class="border-y border-border-dark/30 mb-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-1">Private by default</h3>
          <p class="text-xs text-text-muted">Images are processed in your browser. No upload server is involved.</p>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-1">Exact pixels</h3>
          <p class="text-xs text-text-muted">Use platform presets or enter custom dimensions for any upload requirement.</p>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-1">Smaller files</h3>
          <p class="text-xs text-text-muted">Compress to KB targets with JPG, WebP, PNG, and optional max dimensions.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <div class="mb-5">
      <h2 class="text-2xl font-semibold text-text-primary">Aspect ratio helper</h2>
      <p class="text-sm text-text-muted mt-1">Still here when you need to calculate proportions, but image sizing comes first.</p>
    </div>
    <CalculatorIsland client:load />
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <h2 class="text-xl font-semibold text-text-primary mb-4">What image size means</h2>
    <div class="prose prose-sm text-text-muted space-y-4">
      <p>
        Image size usually means two things: <strong class="text-text-primary">pixel dimensions</strong>, such as 1200x628, and <strong class="text-text-primary">file size</strong>, such as 250 KB. Upload requirements often care about both.
      </p>
      <p>
        Use resize and crop when the platform needs a specific shape. Use compression when the pixels are already right but the file is too large for a form, profile, job application, or CMS.
      </p>
    </div>
  </section>
</Layout>
