---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import FAQ from '../components/ui/FAQ.astro';
import RelatedTools from '../components/ui/RelatedTools.astro';
import CalculatorIsland from '../components/islands/CalculatorIsland';
import { buildWebApplicationLD, buildFAQLD, buildBreadcrumbLD } from '../lib/seo';

const title = 'Aspect Ratio Calculator — Compute, Convert & Compare Ratios Instantly';
const description = 'Free aspect ratio calculator. Enter width and height for instant ratio detection, or enter a ratio to compute dimensions. Find nearest standard ratios with confidence scores.';

const faqs = [
  {
    question: 'How do I calculate the aspect ratio of my image?',
    answer: 'Enter the width and height in pixels. The calculator instantly computes the simplified ratio (e.g., 1920×1080 → 16:9), the decimal ratio, orientation, and the nearest common ratios with percentage differences.',
  },
  {
    question: 'What does "nearest common ratio" mean?',
    answer: 'If your image dimensions don\'t reduce to a well-known ratio exactly (e.g., 1180×820), we find the closest standard ratios and show how far off each is as a percentage. A "very close" match (under 1%) is usually indistinguishable visually.',
  },
  {
    question: 'Can I calculate a dimension from a ratio?',
    answer: 'Yes — switch to "Ratio → Dimension" mode. Enter your target ratio (e.g., 16:9) and one dimension (e.g., width = 1920), and the calculator computes the other (height = 1080).',
  },
  {
    question: 'Why does my ratio simplify to large numbers?',
    answer: 'Ratios like 1179×2556 don\'t share a large common factor, so they simplify to something like 393:852. The "Nearest Common Ratios" section will show you the well-known ratio it\'s closest to (likely 9:19.5 for modern phone screens).',
  },
  {
    question: 'Is this calculator free?',
    answer: 'Yes, completely free with no usage limits. All calculations happen in your browser — nothing is uploaded or tracked.',
  },
];

const jsonLD = [
  buildWebApplicationLD('Aspect Ratio Calculator', description, 'https://imagesize.org/calculator'),
  buildFAQLD(faqs),
  buildBreadcrumbLD([
    { name: 'Home', url: 'https://imagesize.org' },
    { name: 'Calculator', url: 'https://imagesize.org/calculator' },
  ]),
];

const relatedTools = [
  {
    title: 'Image Analyzer',
    description: 'Upload an image for instant analysis and platform compatibility checking.',
    href: '/image',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>',
  },
  {
    title: 'Crop & Resize',
    description: 'Crop, fit, stretch, or resize images to any target size. Live preview with export.',
    href: '/crop-and-resize',
    icon: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6.13 1L6 16a2 2 0 002 2h15"/><path d="M1 6.13L16 6a2 2 0 012 2v15"/></svg>',
  },
];
---

<Layout title={title} description={description} jsonLD={jsonLD}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Calculator', url: '/calculator' },
    ]} />

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-3">
        Aspect Ratio Calculator
      </h1>
      <p class="text-text-muted max-w-2xl">
        Enter width and height for instant ratio detection, or enter a target ratio to compute the matching dimension. On-keystroke precision with nearest-match detection.
      </p>
    </div>

    <!-- Calculator Island -->
    <div class="mb-12">
      <CalculatorIsland client:load />
    </div>

    <!-- On-page SEO explainer -->
    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">How the Calculator Works</h2>
      <div class="text-sm text-text-muted space-y-4 leading-relaxed">
        <p>
          The calculator uses the <strong class="text-text-primary">Euclidean algorithm</strong> to find the greatest common divisor (GCD) of your width and height values, then divides both by the GCD to produce the simplified ratio. For example, 1920÷120 = 16, 1080÷120 = 9, giving <code class="text-teal-400 bg-surface px-1.5 py-0.5 rounded text-xs font-mono">16:9</code>.
        </p>
        <p>
          The <strong class="text-text-primary">nearest common ratio</strong> feature compares your decimal ratio (width/height) against a curated database of standard ratios used across video, photography, social media, cinema, and screen design. Each match includes a percentage difference and a confidence label (exact, very close, close, or approximate).
        </p>
        <p>
          In <strong class="text-text-primary">"Ratio → Dimension" mode</strong>, you supply a target ratio and one known dimension. The calculator computes the other dimension while maintaining the exact proportion — useful for responsive design, print layouts, and video production.
        </p>
      </div>
    </div>

    <!-- FAQ -->
    <div class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Frequently Asked Questions</h2>
      <FAQ items={faqs} />
    </div>

    <!-- Related Tools -->
    <div class="max-w-3xl mx-auto mb-8">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Related Tools</h2>
      <RelatedTools tools={relatedTools} />
    </div>

    <!-- Last Updated -->
    <div class="max-w-3xl mx-auto">
      <p class="text-xs text-text-muted/40">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    </div>
  </div>
</Layout>
