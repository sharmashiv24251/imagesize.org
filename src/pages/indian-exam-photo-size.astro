---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import { buildBreadcrumbLD, buildFAQLD, buildWebApplicationLD } from '../lib/seo';
import { absoluteUrl, site } from '../lib/site';
import { examPages, examRequirements, examSlugFragment } from '../lib/examPages';

const title = 'Indian Exam Photo Size Guide — Crop, Resize & Compress for NEET, UPSC, SSC & More';
const description = 'Exact photo and signature size requirements for NEET, UPSC, SSC, JEE, IBPS, RRB, GATE, CAT, CUET, and PAN Card. Crop and compress your image to the required KB and pixels — free, private, no upload.';
const canonicalUrl = absoluteUrl('/indian-exam-photo-size');

const faqs = [
  {
    question: 'What is the standard photo size for Indian government exams?',
    answer: 'Most NTA exams (NEET, JEE, CUET) require a photo around <strong>800×1000 px</strong> or equivalent passport size, under 300 KB in JPEG format. SSC requires <strong>413×531 px</strong> under 100 KB. IBPS asks for <strong>390×500 px</strong> under 50 KB. Each exam has its own portal — check the current notification before uploading.',
  },
  {
    question: 'What is the signature image size for government exam forms?',
    answer: 'Signatures are usually uploaded at <strong>800×200 px</strong> in JPEG format. SSC and UPSC allow up to 300 KB; IBPS requires the signature to be between 10 KB and 50 KB. Sign on plain white paper with a blue or black pen, scan, and compress before uploading.',
  },
  {
    question: 'Can I resize and compress my exam photo for free without uploading it?',
    answer: 'Yes — click "Fix Your Photo" next to any exam below. The tool opens in your browser and processes your image locally using the Canvas API. Nothing is sent to any server.',
  },
  {
    question: 'What happens if I upload the wrong photo size to an exam portal?',
    answer: 'Portals typically reject oversized files immediately. Some accept the photo but re-compress it heavily, causing blurriness. Cropping to the exact pixel dimensions before compressing gives the best result on all exam portals.',
  },
  {
    question: 'My photo is 16:9 landscape — how do I fix it for a passport-size 1:1 upload?',
    answer: 'Use the Crop tool in any exam page. It lets you select the region to keep and outputs only the cropped, correctly-sized image. For passport-size photos a 1:1 or 2:3 crop is usually needed.',
  },
];

const jsonLD = [
  buildWebApplicationLD(title, description, canonicalUrl),
  buildFAQLD(faqs),
  buildBreadcrumbLD([
    { name: 'Home', url: site.url },
    { name: 'Indian Exam Photo Size', url: canonicalUrl },
  ]),
];
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} jsonLD={jsonLD} tier={1}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Indian Exam Photo Size', url: '/indian-exam-photo-size' },
    ]} />

    <!-- Hero -->
    <div class="mb-10 max-w-3xl">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="text-[11px] px-2 py-1 rounded-full bg-amber-500/10 text-amber-400 border border-amber-500/20">
          🇮🇳 Indian Govt Exams
        </span>
        <span class="text-[11px] px-2 py-1 rounded-full bg-surface border border-border-dark text-text-muted">
          {examPages.length} Exams
        </span>
        <span class="text-[11px] px-2 py-1 rounded-full bg-teal-500/10 text-teal-400 border border-teal-500/20">
          Free · No Upload · Private
        </span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-4 leading-tight">
        Indian Exam Photo &amp; Signature Size Guide
      </h1>
      <p class="text-text-muted leading-relaxed text-base">
        Government exam portals reject photos that are the wrong size or too large. This page lists the exact pixel dimensions and KB limits for every major exam — and lets you <strong class="text-text-primary">crop, resize, and compress your photo</strong> in one click, entirely in your browser.
      </p>
      <p class="text-sm text-amber-400/80 mt-3 flex items-start gap-2">
        <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
        Requirements change every exam cycle. Always verify from the official notification before submitting.
      </p>
    </div>

    <!-- Exam list -->
    <section class="mb-14" id="exam-list">
      <h2 class="text-xl font-semibold text-text-primary mb-6">All Supported Exams</h2>

      <!-- Desktop: scrollable table -->
      <div class="exam-table overflow-x-auto rounded-xl border border-border-dark/50">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border-dark/50 bg-surface">
              <th class="text-left px-5 py-3 text-xs text-text-muted uppercase tracking-wider font-medium">Exam</th>
              <th class="text-left px-4 py-3 text-xs text-text-muted uppercase tracking-wider font-medium">Photo Size</th>
              <th class="text-left px-4 py-3 text-xs text-text-muted uppercase tracking-wider font-medium">Max KB</th>
              <th class="text-left px-4 py-3 text-xs text-text-muted uppercase tracking-wider font-medium">Signature Size</th>
              <th class="text-left px-4 py-3 text-xs text-text-muted uppercase tracking-wider font-medium">Sign Max KB</th>
              <th class="text-left px-4 py-3 text-xs text-text-muted uppercase tracking-wider font-medium">Format</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {examPages.map((page, i) => (
              <tr class={`border-b border-border-dark/30 hover:bg-surface/60 transition-colors group ${i % 2 === 0 ? 'bg-bg' : 'bg-surface/30'}`}>
                <td class="px-5 py-4">
                  <div class="font-medium text-text-primary">{page.exam.name}</div>
                  <div class="text-xs text-text-muted mt-0.5">{page.exam.body} · {page.exam.category}</div>
                </td>
                <td class="px-4 py-4 font-mono text-text-muted whitespace-nowrap">
                  {page.exam.photoW}×{page.exam.photoH}
                </td>
                <td class="px-4 py-4 font-mono text-text-muted whitespace-nowrap">
                  {page.exam.photoMinKb ? `${page.exam.photoMinKb}–${page.exam.photoMaxKb}` : `≤ ${page.exam.photoMaxKb}`} KB
                </td>
                <td class="px-4 py-4 font-mono text-text-muted whitespace-nowrap">
                  {page.exam.signW}×{page.exam.signH}
                </td>
                <td class="px-4 py-4 font-mono text-text-muted whitespace-nowrap">
                  {page.exam.signMinKb ? `${page.exam.signMinKb}–${page.exam.signMaxKb}` : `≤ ${page.exam.signMaxKb}`} KB
                </td>
                <td class="px-4 py-4">
                  <span class="text-xs text-text-muted uppercase">{page.exam.format.replace('_or_', '/')}</span>
                </td>
                <td class="px-4 py-4 text-right">
                  <a
                    href={`/${page.slug}`}
                    id={`fix-photo-${examSlugFragment(page)}`}
                    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-teal-500/10 border border-teal-500/25 text-xs text-teal-300 font-medium hover:bg-teal-500/20 hover:border-teal-500/40 transition-all group-hover:border-teal-500/40 whitespace-nowrap"
                  >
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                    </svg>
                    Fix Your Photo
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile: cards -->
      <div class="exam-cards space-y-4">
        {examPages.map((page) => (
          <div class="bg-surface rounded-xl border border-border-dark/50 p-4">
            <div class="flex items-start justify-between gap-3 mb-3">
              <div>
                <div class="font-semibold text-text-primary">{page.exam.name}</div>
                <div class="text-xs text-text-muted mt-0.5">{page.exam.body} · {page.exam.category}</div>
              </div>
              <span class="text-[10px] px-2 py-1 rounded-full bg-amber-500/10 text-amber-400 border border-amber-500/20 shrink-0 uppercase">
                {page.exam.format.replace('_or_', '/')}
              </span>
            </div>
            <div class="grid grid-cols-2 gap-3 mb-4">
              <div class="bg-bg rounded-lg border border-border-dark/40 px-3 py-2">
                <div class="text-[10px] text-text-muted uppercase tracking-wider mb-1">Photo</div>
                <div class="font-mono text-sm text-text-primary">{page.exam.photoW}×{page.exam.photoH}</div>
                <div class="text-xs text-text-muted mt-0.5">
                  {page.exam.photoMinKb ? `${page.exam.photoMinKb}–${page.exam.photoMaxKb} KB` : `≤ ${page.exam.photoMaxKb} KB`}
                </div>
              </div>
              <div class="bg-bg rounded-lg border border-border-dark/40 px-3 py-2">
                <div class="text-[10px] text-text-muted uppercase tracking-wider mb-1">Signature</div>
                <div class="font-mono text-sm text-text-primary">{page.exam.signW}×{page.exam.signH}</div>
                <div class="text-xs text-text-muted mt-0.5">≤ {page.exam.signMaxKb} KB</div>
              </div>
            </div>
            <a
              href={`/${page.slug}`}
              id={`fix-photo-mobile-${examSlugFragment(page)}`}
              class="w-full flex items-center justify-center gap-2 py-2.5 rounded-lg bg-teal-500/10 border border-teal-500/25 text-sm text-teal-300 font-medium hover:bg-teal-500/20 hover:border-teal-500/40 transition-all"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
              </svg>
              Fix Your Photo for {page.exam.name}
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- How it works -->
    <section class="mb-14 max-w-3xl">
      <h2 class="text-xl font-semibold text-text-primary mb-6">How to Fix Your Exam Photo in 3 Steps</h2>
      <div class="grid gap-4 sm:grid-cols-3">
        {[
          {
            step: '1',
            title: 'Click "Fix Your Photo"',
            desc: 'Select your exam from the table above. The tool opens with the exact pixel dimensions pre-loaded.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/>',
          },
          {
            step: '2',
            title: 'Drop your image & Crop',
            desc: 'Upload your photo (even a 16:9 selfie). Choose Crop to fill the frame, or Fit to keep the full face. Export as JPG.',
            icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>',
          },
          {
            step: '3',
            title: 'Compress to KB limit',
            desc: 'Switch to the Compress tab, set the target KB from your exam notification, and download the ready-to-upload file.',
            icon: '<path d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1-4l-3 3m0 0l-3-3m3 3V4"/>',
          },
        ].map((s) => (
          <div class="bg-surface rounded-xl border border-border-dark/50 p-5">
            <div class="flex items-center gap-3 mb-3">
              <span class="w-7 h-7 rounded-full bg-teal-500/15 border border-teal-500/30 text-teal-400 text-xs font-bold flex items-center justify-center shrink-0">
                {s.step}
              </span>
              <h3 class="text-sm font-semibold text-text-primary">{s.title}</h3>
            </div>
            <p class="text-xs text-text-muted leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Common background requirements callout -->
    <section class="mb-14 max-w-3xl">
      <div class="bg-amber-500/5 border border-amber-500/20 rounded-xl p-5">
        <h2 class="text-sm font-semibold text-amber-400 mb-3 flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Common Photo Rules Across All Exams
        </h2>
        <ul class="space-y-2 text-sm text-text-muted">
          <li class="flex items-start gap-2">
            <svg class="w-3.5 h-3.5 mt-1 shrink-0 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            White or light-coloured background — no patterns, walls, or outdoor scenes.
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-3.5 h-3.5 mt-1 shrink-0 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            Both ears visible, no cap, no sunglasses, no head covering (except religious).
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-3.5 h-3.5 mt-1 shrink-0 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            Recent photo — typically taken within the last 3 months.
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-3.5 h-3.5 mt-1 shrink-0 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            Name + date of photograph printed at the bottom for NTA exams.
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-3.5 h-3.5 mt-1 shrink-0 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            Signature on plain white paper, black or blue ink — not in CAPITAL LETTERS.
          </li>
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-3xl mx-auto mb-12">
      <h2 class="text-xl font-semibold text-text-primary mb-4">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <details
            class="group bg-surface rounded-xl border border-border-dark/50 overflow-hidden"
            id={`exam-hub-faq-${i}`}
          >
            <summary class="flex cursor-pointer items-center justify-between px-4 py-3.5 text-sm font-medium text-text-primary select-none hover:text-teal-300 transition-colors list-none">
              <span>{faq.question}</span>
              <svg class="w-4 h-4 shrink-0 text-text-muted transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-4 pb-4 pt-1 text-sm text-text-muted leading-relaxed" set:html={faq.answer} />
          </details>
        ))}
      </div>
    </section>

    <div class="max-w-3xl mx-auto">
      <p class="text-xs text-text-muted/40">
        Last updated: {new Date().toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}
        · Requirements verified from official portals. Always confirm from the current exam notification.
      </p>
    </div>

  </div>
</Layout>

<style>
  /* Table on desktop, cards on mobile — scoped to avoid Tailwind v4 ordering issues */
  .exam-cards { display: flex; flex-direction: column; }
  .exam-table { display: none; }

  @media (min-width: 768px) {
    .exam-table { display: block; }
    .exam-cards { display: none; }
  }
</style>
